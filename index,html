<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PagoDoc</title>
    <link rel="manifest" href="./manifest.json">
    <meta name="theme-color" content="#1a3c8a">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <link rel="icon" href="./assets/icon-192.png">
    <link rel="apple-touch-icon" href="./assets/icon-192.png">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<style>
:root {
    --blue:#1a3c8a; --blue2:#1e5bbd; --green:#26a641; --green2:#43e97b;
    --ink:#0d1117; --ink-s:#3a3a5c; --ink-m:#7b7b9a;
    --surface:#ffffff; --surf2:#f4f6fb; --border:#e2e8f0;
    --grad:linear-gradient(135deg,var(--blue) 0%,var(--blue2) 55%,var(--green) 100%);
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'DM Sans',sans-serif;background:var(--surf2);color:var(--ink);min-height:100vh;overflow-x:hidden;}

/* ── ONBOARDING ── */
#onboarding{position:fixed;inset:0;z-index:9999;background:var(--grad);display:flex;flex-direction:column;overflow-y:auto;}
.ob-splash{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:2rem;text-align:center;min-height:100vh;animation:fadeUp 0.6s ease both;}
.ob-logo-big{width:110px;height:110px;filter:drop-shadow(0 8px 24px rgba(0,0,0,0.3));}
.ob-logo-wrap{margin-bottom:1.5rem;display:flex;align-items:center;justify-content:center;}
.ob-logo-img{width:160px;height:160px;object-fit:contain;filter:drop-shadow(0 8px 28px rgba(0,0,0,0.35));border-radius:28px;}
.ob-title{font-family:'Playfair Display',serif;font-size:3rem;color:white;letter-spacing:2px;margin-bottom:0.4rem;}
.ob-title span{color:#a8f5c0;}
.ob-subtitle{color:rgba(255,255,255,0.75);font-size:1rem;margin-bottom:3rem;font-weight:300;}
.ob-start-btn{background:white;color:var(--blue);border:none;border-radius:50px;padding:1rem 3rem;font-family:'DM Sans',sans-serif;font-size:1rem;font-weight:700;cursor:pointer;box-shadow:0 8px 32px rgba(0,0,0,0.25);transition:all 0.25s;letter-spacing:0.5px;}
.ob-start-btn:hover{transform:translateY(-3px) scale(1.03);box-shadow:0 14px 40px rgba(0,0,0,0.3);}
.ob-note{color:rgba(255,255,255,0.45);font-size:0.75rem;margin-top:1.25rem;}

.ob-steps{display:none;flex-direction:column;min-height:100vh;padding-bottom:2rem;}
.ob-steps.active{display:flex;}
.ob-progress{background:rgba(255,255,255,0.15);padding:1.1rem 1.5rem;display:flex;align-items:center;gap:1rem;position:sticky;top:0;z-index:10;backdrop-filter:blur(8px);}
.ob-dots{display:flex;gap:8px;flex:1;}
.ob-dot{flex:1;height:4px;border-radius:4px;background:rgba(255,255,255,0.25);transition:background 0.3s;}
.ob-dot.done{background:#a8f5c0;}
.ob-dot.active{background:white;}
.ob-step-lbl{color:white;font-size:0.78rem;font-weight:600;white-space:nowrap;}
.ob-card{background:white;border-radius:20px 20px 0 0;margin:0 0.75rem;flex:1;padding:2rem 1.5rem;animation:slideUp 0.35s ease both;}
.ob-icon{font-size:2.2rem;margin-bottom:0.5rem;}
.ob-h{font-family:'Playfair Display',serif;font-size:1.5rem;color:var(--blue);margin-bottom:0.4rem;}
.ob-desc{font-size:0.85rem;color:var(--ink-m);margin-bottom:1.5rem;line-height:1.55;}
.og{margin-bottom:1rem;}
.og label{display:block;font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.6px;color:var(--ink-s);margin-bottom:0.3rem;}
.og input,.og select,.og textarea{width:100%;padding:0.7rem 0.9rem;border:1.5px solid var(--border);border-radius:9px;font-family:'DM Sans',sans-serif;font-size:0.9rem;color:var(--ink);background:var(--surface);transition:border-color 0.2s;-webkit-appearance:none;}
.og input:focus,.og select:focus,.og textarea:focus{outline:none;border-color:var(--blue2);box-shadow:0 0 0 3px rgba(30,91,189,0.1);}
.og textarea{resize:vertical;min-height:70px;}
.og2{display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;}
.ob-upload{border:2px dashed var(--border);border-radius:12px;padding:1.5rem;text-align:center;cursor:pointer;transition:all 0.2s;position:relative;overflow:hidden;background:var(--surf2);}
.ob-upload:hover{border-color:var(--blue2);background:#f0f4ff;}
.ob-upload input[type="file"]{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%;}
.ob-upload img{max-height:90px;max-width:100%;object-fit:contain;margin-bottom:0.4rem;}
.ob-upload p{font-size:0.8rem;color:var(--ink-m);}
.ob-color-row{display:flex;gap:0.75rem;align-items:center;}
.ob-color-row input[type="color"]{width:50px;height:42px;padding:3px;cursor:pointer;border-radius:8px;border:1.5px solid var(--border);}
.ob-color-row span{font-size:0.82rem;color:var(--ink-s);}
.ob-cat-item{display:flex;gap:0.5rem;margin-bottom:0.45rem;align-items:center;}
.ob-cat-item input{flex:1;padding:0.55rem 0.75rem;font-size:0.85rem;border:1.5px solid var(--border);border-radius:7px;font-family:'DM Sans',sans-serif;}
.ob-cat-item input:focus{outline:none;border-color:var(--blue2);}
.ob-cat-del{background:#fee2e2;border:none;border-radius:6px;color:#dc2626;width:32px;height:32px;cursor:pointer;font-size:1rem;flex-shrink:0;display:flex;align-items:center;justify-content:center;}
.ob-cat-del:hover{background:#fecaca;}
.ob-cat-add{width:100%;background:none;border:1.5px dashed var(--border);color:var(--ink-s);padding:0.55rem;border-radius:8px;font-family:'DM Sans',sans-serif;font-size:0.82rem;cursor:pointer;margin-top:0.25rem;transition:all 0.2s;}
.ob-cat-add:hover{border-color:var(--blue2);color:var(--blue);}
.ob-nav{display:flex;gap:0.75rem;margin-top:1.5rem;}
.ob-next{flex:1;padding:0.9rem;border:none;border-radius:50px;background:var(--grad);color:white;font-family:'DM Sans',sans-serif;font-weight:700;font-size:0.9rem;cursor:pointer;letter-spacing:0.5px;box-shadow:0 4px 16px rgba(26,60,138,0.3);transition:all 0.2s;}
.ob-next:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(26,60,138,0.4);}
.ob-back{padding:0.9rem 1.25rem;border:1.5px solid var(--border);border-radius:50px;background:white;color:var(--ink-s);font-family:'DM Sans',sans-serif;font-weight:600;font-size:0.9rem;cursor:pointer;transition:all 0.2s;}
.ob-back:hover{border-color:var(--blue2);color:var(--blue);}
.ob-skip{text-align:center;margin-top:0.75rem;}
.ob-skip a{color:var(--ink-m);font-size:0.78rem;cursor:pointer;text-decoration:underline;}
.ob-summary{background:var(--surf2);border-radius:12px;padding:1rem;text-align:left;margin:1rem 0;font-size:0.82rem;line-height:1.8;}

/* ── APP ── */
#app{display:none;}
#app.active{display:block;}
.topbar{background:var(--grad);color:white;display:flex;align-items:center;justify-content:space-between;padding:0 1.25rem;height:54px;position:sticky;top:0;z-index:100;box-shadow:0 2px 16px rgba(26,60,138,0.35);}
.tb-brand{display:flex;align-items:center;gap:9px;}
.tb-logo{width:32px;height:32px;flex-shrink:0;}
.tb-name{font-family:'DM Sans',sans-serif;font-weight:700;font-size:1.15rem;color:white;}
.tb-name span{color:#a8f5c0;}
.tb-acts{display:flex;gap:0.4rem;align-items:center;}
.bi{background:rgba(255,255,255,0.14);border:1px solid rgba(255,255,255,0.22);color:white;padding:0.42rem 0.75rem;border-radius:7px;cursor:pointer;font-size:0.74rem;font-weight:600;display:flex;align-items:center;gap:4px;transition:all 0.2s;white-space:nowrap;font-family:'DM Sans',sans-serif;}
.bi:hover{background:rgba(255,255,255,0.26);}
.bi.g{background:var(--green);border-color:var(--green2);}
.bi.g:hover{background:#1e8f35;}
.layout{display:grid;grid-template-columns:400px 1fr;min-height:calc(100vh - 54px);}
@media(max-width:900px){.layout{grid-template-columns:1fr;}.preview-col{display:none;}}
.sidebar{background:var(--surface);border-right:1px solid var(--border);overflow-y:auto;height:calc(100vh - 54px);position:sticky;top:54px;}
.sb-tabs{display:flex;border-bottom:1px solid var(--border);background:var(--surf2);overflow-x:auto;}
.tb{flex:1;padding:0.7rem 0.35rem;border:none;background:transparent;font-family:'DM Sans',sans-serif;font-size:0.68rem;font-weight:700;color:var(--ink-m);cursor:pointer;text-transform:uppercase;letter-spacing:0.4px;border-bottom:2.5px solid transparent;transition:all 0.2s;white-space:nowrap;}
.tb.active{color:var(--blue);border-bottom-color:var(--blue);background:var(--surface);}
.tp{display:none;padding:1.2rem;}
.tp.active{display:block;}
.sl{font-size:0.62rem;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:var(--ink-m);margin-bottom:0.65rem;padding-bottom:0.4rem;border-bottom:1px solid var(--border);}
.fg{margin-bottom:0.8rem;position:relative;}
.fg label{display:block;font-size:0.7rem;font-weight:600;color:var(--ink-s);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:0.28rem;}
.fg input,.fg select,.fg textarea{width:100%;padding:0.58rem 0.8rem;border:1.5px solid var(--border);border-radius:7px;font-family:'DM Sans',sans-serif;font-size:0.875rem;color:var(--ink);background:var(--surface);transition:all 0.2s;-webkit-appearance:none;}
.fg input:focus,.fg select:focus,.fg textarea:focus{outline:none;border-color:var(--blue2);box-shadow:0 0 0 3px rgba(30,91,189,0.1);}
.rf{background:var(--surf2);font-family:'DM Mono',monospace;font-weight:600;}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:0.6rem;}
textarea{resize:vertical;min-height:56px;}
.ac-wrap{position:relative;}
.ac-list{position:absolute;top:100%;left:0;right:0;background:white;border:1.5px solid var(--border);border-top:none;border-radius:0 0 8px 8px;max-height:200px;overflow-y:auto;z-index:500;box-shadow:0 8px 24px rgba(0,0,0,0.1);display:none;}
.ac-item{padding:0.65rem 0.8rem;cursor:pointer;border-bottom:1px solid var(--surf2);transition:background 0.15s;}
.ac-item:hover,.ac-item.active{background:var(--surf2);}
.ac-item strong{display:block;font-size:0.875rem;}
.ac-item small{font-size:0.72rem;color:var(--ink-m);}
.ctag{display:inline-block;padding:0.1rem 0.45rem;border-radius:20px;font-size:0.65rem;font-weight:700;margin-left:0.3rem;vertical-align:middle;}
.ctag.new{background:#fef3c7;color:#92400e;}
.ctag.saved{background:#d1fae5;color:#065f46;}
.btn{width:100%;padding:0.7rem;border:none;border-radius:8px;font-family:'DM Sans',sans-serif;font-weight:700;font-size:0.8rem;text-transform:uppercase;letter-spacing:0.4px;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px;transition:all 0.2s;margin-bottom:0.5rem;}
.btn:last-child{margin-bottom:0;}
.btn:hover{transform:translateY(-1px);opacity:0.9;}
.bp{background:var(--grad);color:white;}
.bs{background:linear-gradient(135deg,var(--green),#1e8f35);color:white;}
.bo{background:transparent;border:1.5px solid var(--border);color:var(--ink-s);}
.bo:hover{border-color:var(--blue2);color:var(--blue);background:#f0f4ff;}
.bg{margin-top:1rem;}
.up-area{border:2px dashed var(--border);border-radius:10px;padding:1.1rem;text-align:center;cursor:pointer;transition:all 0.2s;position:relative;overflow:hidden;background:var(--surf2);}
.up-area:hover{border-color:var(--blue2);background:#f0f4ff;}
.up-area img{max-height:70px;max-width:100%;object-fit:contain;}
.up-area p{font-size:0.76rem;color:var(--ink-m);margin-top:0.35rem;}
.up-area input[type="file"]{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%;}
.cr{display:flex;gap:0.5rem;align-items:center;}
.cr input[type="color"]{width:42px;height:36px;padding:2px;cursor:pointer;border-radius:6px;border:1.5px solid var(--border);}
.cr span{font-size:0.77rem;color:var(--ink-s);}
.hi,.cc{background:var(--surf2);border:1px solid var(--border);border-radius:8px;padding:0.7rem;margin-bottom:0.5rem;cursor:pointer;transition:all 0.2s;}
.hi:hover,.cc:hover{border-color:var(--blue2);box-shadow:0 2px 8px rgba(26,60,138,0.1);}
.hi h4,.cc h4{font-size:0.875rem;margin-bottom:0.18rem;}
.hi p,.cc p{font-size:0.72rem;color:var(--ink-m);}
.hi-a{font-family:'DM Mono',monospace;font-weight:700;color:var(--green);}
.cc{display:flex;justify-content:space-between;align-items:flex-start;}
.ca{display:flex;gap:0.3rem;}
.bx{padding:0.22rem 0.48rem;border-radius:5px;border:1px solid var(--border);background:white;font-size:0.7rem;cursor:pointer;transition:all 0.15s;font-family:'DM Sans',sans-serif;}
.bx:hover{background:var(--surf2);}
.bx.d{color:#dc2626;border-color:#fecaca;}
.bx.d:hover{background:#fee2e2;}
.empty{text-align:center;padding:2rem 1rem;color:var(--ink-m);font-size:0.82rem;}
.preview-col{padding:2rem;display:flex;flex-direction:column;align-items:center;overflow-y:auto;height:calc(100vh - 54px);position:sticky;top:54px;}
.cert{width:21.59cm;min-height:27.94cm;background:white;padding:1.4cm 1.8cm;position:relative;box-shadow:0 4px 40px rgba(0,0,0,0.15);color:#000;display:flex;flex-direction:column;-webkit-font-smoothing:antialiased;flex-shrink:0;}
.cstripe{position:absolute;top:0;left:0;right:0;height:10px;background:var(--grad);}
.chead{display:flex;justify-content:space-between;align-items:center;margin-bottom:2rem;padding-top:0.5rem;}
.cbiz{width:175px;min-height:75px;display:flex;align-items:center;justify-content:center;}
.cbiz img{max-width:100%;max-height:85px;object-fit:contain;display:block;}
.clogoph{width:155px;height:65px;border:2px dashed #c8d0e0;border-radius:8px;display:flex;align-items:center;justify-content:center;color:#a8b0c0;font-size:0.7rem;text-align:center;padding:0.5rem;background:#f8f9fc;}
.cco{text-align:right;}
.cco h3{font-family:'Playfair Display',serif;font-size:1rem;color:var(--blue);margin-bottom:4px;}
.cco p{font-size:0.72rem;color:#374151;margin:1px 0;line-height:1.5;}
.ctitle{text-align:center;margin-bottom:1.6rem;border-top:1px solid #e8edf5;border-bottom:1px solid #e8edf5;padding:1rem 0;}
.ctitle h2{font-family:'Playfair Display',serif;font-size:1.8rem;color:var(--blue);letter-spacing:5px;margin-bottom:4px;}
.cnum{font-family:'DM Mono',monospace;font-size:0.9rem;font-weight:700;color:#dc2626;}
.cintro{font-size:0.88rem;margin-bottom:1.6rem;text-align:justify;line-height:1.7;color:#374151;}
.dtbl{width:100%;border-collapse:collapse;margin-bottom:2rem;}
.dtbl td{padding:9px 12px;border-bottom:1px solid #f0f4f8;font-size:0.86rem;}
.tl{font-weight:700;color:var(--blue);width:30%;font-size:0.7rem;text-transform:uppercase;letter-spacing:0.4px;}
.tv{font-size:0.94rem;}
.pr{background:#f0f7ff;}
.prt{font-size:1.4rem;font-weight:800;color:var(--blue);font-family:'DM Mono',monospace;}
.cfoot{margin-top:auto;display:flex;justify-content:space-between;align-items:flex-end;padding-bottom:0.5rem;}
.sbox{width:230px;text-align:center;}
.simg{max-width:165px;max-height:62px;display:block;margin:0 auto 4px;object-fit:contain;}
.sph{width:165px;height:55px;border:1px dashed #bbb;display:flex;align-items:center;justify-content:center;color:#bbb;font-size:0.68rem;margin:0 auto 4px;}
.sline{border-top:2px solid #111;padding-top:4px;}
.sline p{font-size:0.7rem;}
.sname{font-family:'Playfair Display',serif;font-size:1.1rem;font-style:italic;color:var(--blue);margin-bottom:2px;}
.ccontact{text-align:right;font-size:0.68rem;color:#6b7280;line-height:1.65;}
.cpow{text-align:center;margin-top:0.8rem;padding-top:0.5rem;border-top:1px solid #eef2f8;font-size:0.58rem;color:#c0c8d8;letter-spacing:0.4px;}
.cpow strong{color:var(--blue);opacity:0.45;}
.fab{position:fixed;bottom:1.5rem;right:1.5rem;width:52px;height:52px;border-radius:50%;background:var(--grad);color:white;border:none;cursor:pointer;box-shadow:0 4px 18px rgba(26,60,138,0.4);display:flex;align-items:center;justify-content:center;transition:all 0.3s;z-index:200;}
.fab:hover{transform:scale(1.08);box-shadow:0 6px 24px rgba(26,60,138,0.55);}
.fab svg{width:22px;height:22px;}
.mo{position:fixed;inset:0;background:rgba(0,0,0,0.55);z-index:1000;display:flex;align-items:center;justify-content:center;padding:1rem;opacity:0;pointer-events:none;transition:opacity 0.2s;}
.mo.open{opacity:1;pointer-events:all;}
.mo-box{background:white;border-radius:14px;width:100%;max-width:450px;max-height:85vh;overflow-y:auto;padding:1.5rem;transform:translateY(20px);transition:transform 0.25s;box-shadow:0 20px 60px rgba(0,0,0,0.2);}
.mo.open .mo-box{transform:translateY(0);}
.mo-box h3{font-family:'Playfair Display',serif;font-size:1.2rem;margin-bottom:1rem;color:var(--ink);}
.mo-x{float:right;background:none;border:none;font-size:1.2rem;cursor:pointer;color:var(--ink-m);}
.cat-item{display:flex;gap:0.4rem;margin-bottom:0.4rem;align-items:center;}
.cat-item input{flex:1;padding:0.48rem 0.7rem;font-size:0.84rem;border:1.5px solid var(--border);border-radius:6px;font-family:'DM Sans',sans-serif;}
.cat-item input:focus{outline:none;border-color:var(--blue2);}
.cat-del{background:#fee2e2;border:none;border-radius:5px;color:#dc2626;width:28px;height:28px;cursor:pointer;font-size:0.85rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.cat-del:hover{background:#fecaca;}
.cat-add-b{width:100%;background:none;border:1.5px dashed var(--border);color:var(--ink-s);padding:0.48rem;border-radius:7px;font-family:'DM Sans',sans-serif;font-size:0.8rem;cursor:pointer;margin-top:0.2rem;transition:all 0.2s;}
.cat-add-b:hover{border-color:var(--blue2);color:var(--blue);}
.toast{position:fixed;bottom:5rem;left:50%;transform:translateX(-50%) translateY(20px);background:var(--ink);color:white;padding:0.62rem 1.15rem;border-radius:30px;font-size:0.78rem;font-weight:500;z-index:2000;opacity:0;transition:all 0.3s;pointer-events:none;white-space:nowrap;}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0);}
.cfg-hint{text-align:center;padding:0.4rem;font-size:0.74rem;color:var(--ink-m);margin-bottom:0.5rem;}
.cfg-hint a{color:var(--blue);cursor:pointer;text-decoration:underline;}
@media print{body{background:white!important;}#onboarding,.topbar,.sidebar,.fab,.no-print{display:none!important;}.layout{display:block;}.preview-col{display:block!important;height:auto;padding:0;position:static;overflow:visible;}.cert{box-shadow:none!important;margin:0!important;width:100%!important;padding:1.4cm 1.8cm!important;min-height:0!important;}@page{size:letter;margin:0;}}
@keyframes slideUp{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes fi{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:translateY(0)}}
.fi{animation:fi 0.22s ease both;}
</style>
</head>
<body>

<!-- ══ ONBOARDING ══ -->
<div id="onboarding">
  <div id="ob-splash" class="ob-splash">

    <!-- ════════════════════════════════════════
         LOGO DE LA APP
         Reemplaza ./assets/logo-pagodoc.png
         con tu imagen real. El SVG de abajo
         es el placeholder que se muestra si
         la imagen no se encuentra.
    ════════════════════════════════════════ -->
    <div class="ob-logo-wrap">
      <img
        id="ob-app-logo"
        src="./assets/logo-pagodoc.png"
        alt="PagoDoc"
        class="ob-logo-img"
        onerror="this.style.display='none'; document.getElementById('ob-logo-svg').style.display='block';"
      >
      <!-- Placeholder SVG (se oculta si existe la imagen) -->
      <svg id="ob-logo-svg" class="ob-logo-big" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" style="display:none;">
        <defs>
          <linearGradient id="lg1" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" style="stop-color:#4fc3f7"/><stop offset="100%" style="stop-color:#43e97b"/></linearGradient>
