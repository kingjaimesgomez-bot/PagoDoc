<script>
const K={cl:'pd_cl',hs:'pd_hs',cfg:'pd_cfg',cats:'pd_cats',inv:'pd_inv',logo:'pd_logo',sig:'pd_sig',setup:'pd_setup'};
const DEF_CATS=['Consultoría','Asesoría','Servicios profesionales','Venta de producto','Arriendo','Educación / Clases','Diseño gráfico','Programación / Web','Salud / Medicina','Belleza / Estética','Mecánica / Reparación','Otros'];
const OB_CATS=['Consultoría / Asesoría','Venta de producto','Servicio profesional','Educación / Clases','Diseño / Creatividad','Salud / Bienestar','Otros'];

const $=id=>document.getElementById(id);
function get(k){try{const v=localStorage.getItem(k);return v?JSON.parse(v):null;}catch{return null;}}
function set(k,v){try{localStorage.setItem(k,JSON.stringify(v));}catch(e){}}
function toast(m,ms=2400){const el=$('toast');el.textContent=m;el.classList.add('show');setTimeout(()=>el.classList.remove('show'),ms);}
function fmtC(n,c){const m={COP:{locale:'es-CO',currency:'COP',d:0},USD:{locale:'en-US',currency:'USD',d:2},EUR:{locale:'de-DE',currency:'EUR',d:2}};const cfg=m[c]||m.COP;return new Intl.NumberFormat(cfg.locale,{style:'currency',currency:cfg.currency,minimumFractionDigits:cfg.d,maximumFractionDigits:cfg.d}).format(n);}
function fmtD(s){if(!s)return'—';const[y,mo,d]=s.split('-').map(Number);return new Date(y,mo-1,d).toLocaleDateString('es-CO',{day:'numeric',month:'long',year:'numeric'});}
function toB64(f){return new Promise((res,rej)=>{const r=new FileReader();r.onload=e=>res(e.target.result);r.onerror=rej;r.readAsDataURL(f);});}

/* ══ ONBOARDING ══ */
let obStep=0;
function startOB(){$('ob-splash').style.display='none';$('ob-steps').classList.add('active');renderObCats();goStep(0);}
function goStep(n){
  if(n>0&&obStep===0){const nm=$('ob-name').value.trim();if(!nm){$('ob-name').focus();$('ob-name').style.borderColor='#dc2626';toast('⚠️ El nombre del negocio es requerido');return;}$('ob-name').style.borderColor='';}
  for(let i=0;i<5;i++){const el=$('ob-s'+i);if(el)el.style.display='none';}
  const t=$('ob-s'+n);if(t){t.style.display='block';t.style.animation='slideUp 0.35s ease both';}
  for(let i=0;i<5;i++){const d=$('dot-'+i);if(d){d.className='ob-dot';if(i<n)d.classList.add('done');else if(i===n)d.classList.add('active');}}
  $('ob-lbl').textContent=`Paso ${n+1} de 5`;
  obStep=n;
  if(n===4)buildSum();
}
function buildSum(){const nm=$('ob-name').value||'—';const nit=$('ob-nit').value||'—';const tel=$('ob-tel').value||'—';const city=$('ob-city').value||'—';const rep=$('ob-rep').value||'—';$('ob-sum').innerHTML=`<b>🏢 ${nm}</b><br>NIT: ${nit} | Tel: ${tel}<br>Ciudad: ${city}<br>Representante: ${rep}`;}
async function obLogo(e){const f=e.target.files[0];if(!f)return;const b=await toB64(f);set(K.logo,b);$('ob-logo-prev').src=b;$('ob-logo-prev').style.display='block';$('ob-logo-txt').style.display='none';}
async function obSig(e){const f=e.target.files[0];if(!f)return;const b=await toB64(f);set(K.sig,b);$('ob-sig-prev').src=b;$('ob-sig-prev').style.display='block';$('ob-sig-txt').style.display='none';}
function renderObCats(){$('ob-cats').innerHTML=[...OB_CATS].map((c,i)=>`<div class="ob-cat-item" id="obc-${i}"><input type="text" value="${c}" id="obci-${i}"><button class="ob-cat-del" onclick="document.getElementById('obc-${i}').remove()">✕</button></div>`).join('');}
function obAddCat(){const ed=$('ob-cats'),i=ed.children.length;const div=document.createElement('div');div.className='ob-cat-item fi';div.id='obc-'+i;div.innerHTML=`<input type="text" id="obci-${i}" placeholder="Nuevo producto o servicio" autofocus><button class="ob-cat-del" onclick="this.parentElement.remove()">✕</button>`;ed.appendChild(div);div.querySelector('input').focus();}
function getObCats(){return[...document.querySelectorAll('#ob-cats input')].map(i=>i.value.trim()).filter(Boolean);}
function finishOB(){
  set(K.cfg,{name:$('ob-name').value.trim(),nit:$('ob-nit').value.trim(),tel:$('ob-tel').value.trim(),city:$('ob-city').value.trim(),email:$('ob-email').value.trim(),web:$('ob-web').value.trim(),slogan:$('ob-slogan').value.trim(),rep:$('ob-rep').value.trim(),repCc:$('ob-rep-cc').value.trim(),cargo:$('ob-cargo').value.trim(),intro:$('ob-intro').value.trim(),color:$('ob-color').value});
  const cats=getObCats();if(cats.length)set(K.cats,cats);
  set(K.setup,true);launchApp();
}
function skipOB(){set(K.setup,true);launchApp();}
function reopenOB(){$('app').classList.remove('active');$('onboarding').style.display='flex';$('ob-splash').style.display='none';$('ob-steps').classList.add('active');const c=get(K.cfg)||{};$('ob-name').value=c.name||'';$('ob-nit').value=c.nit||'';$('ob-tel').value=c.tel||'';$('ob-city').value=c.city||'';$('ob-email').value=c.email||'';$('ob-web').value=c.web||'';$('ob-slogan').value=c.slogan||'';$('ob-rep').value=c.rep||'';$('ob-rep-cc').value=c.repCc||'';$('ob-cargo').value=c.cargo||'';$('ob-intro').value=c.intro||'';$('ob-color').value=c.color||'#1a3c8a';renderObCats();goStep(0);}
function launchApp(){$('onboarding').style.display='none';$('app').classList.add('active');initApp();}

/* ══ APP ══ */
function initApp(){
  const t=new Date();$('inp-date').value=`${t.getFullYear()}-${String(t.getMonth()+1).padStart(2,'0')}-${String(t.getDate()).padStart(2,'0')}`;
  updInv(getInv());$('cfg-inv').value=getInv();renderSvc();loadCfgForm();
  const logo=get(K.logo);if(logo)rLogo(logo);
  const sig=get(K.sig);if(sig)rSig(sig);
  $('pay-form').querySelectorAll('input,select,textarea').forEach(el=>{el.addEventListener('input',updC);el.addEventListener('change',updC);});
  updC();
}

/* tabs & modals */
function swTab(n,btn){document.querySelectorAll('.tp').forEach(p=>p.classList.remove('active'));document.querySelectorAll('.tb').forEach(b=>b.classList.remove('active'));$('tab-'+n).classList.add('active');if(btn)btn.classList.add('active');if(n==='clientes')renderCL();if(n==='historial')renderHS();}
function openMo(id){$(id).classList.add('open');if(id==='mo-cats')renderCatsEd();}
function closeMo(id){$(id).classList.remove('open');}
document.querySelectorAll('.mo').forEach(m=>m.addEventListener('click',e=>{if(e.target===m)m.classList.remove('open');}));

/* config */
function loadCfgForm(){const c=get(K.cfg)||{};$('cfg-name').value=c.name||'';$('cfg-nit').value=c.nit||'';$('cfg-rep').value=c.rep||'';$('cfg-cargo').value=c.cargo||'';$('cfg-rep-cc').value=c.repCc||'';$('cfg-tel').value=c.tel||'';$('cfg-email').value=c.email||'';$('cfg-web').value=c.web||'';$('cfg-city').value=c.city||'';$('cfg-slogan').value=c.slogan||'';$('cfg-intro').value=c.intro||'';$('cfg-color').value=c.color||'#1a3c8a';applyCol();updC();}
function saveCfg(){set(K.cfg,{name:$('cfg-name').value,nit:$('cfg-nit').value,rep:$('cfg-rep').value,cargo:$('cfg-cargo').value,repCc:$('cfg-rep-cc').value,tel:$('cfg-tel').value,email:$('cfg-email').value,web:$('cfg-web').value,city:$('cfg-city').value,slogan:$('cfg-slogan').value,intro:$('cfg-intro').value,color:$('cfg-color').value});}
function applyCol(){const col=$('cfg-color').value;document.documentElement.style.setProperty('--blue',col);document.querySelectorAll('.tl,.cco h3,.ctitle h2,.prt,.sname').forEach(el=>el.style.color=col);$('.cstripe').style.background=`linear-gradient(90deg,${col},${col}bb,#26a641)`;}

/* logo & sig */
async function hLogo(e){const f=e.target.files[0];if(!f)return;const b=await toB64(f);set(K.logo,b);rLogo(b);toast('✅ Logo actualizado');}
function rLogo(b){const img=$('cert-logo-img'),ph=$('cert-logo-ph'),p=$('cfg-logo-p'),t=$('cfg-logo-t');if(b){img.src=b;img.style.display='block';ph.style.display='none';p.src=b;p.style.display='block';t.style.display='none';}else{img.style.display='none';ph.style.display='flex';p.style.display='none';t.style.display='block';}}
function rmLogo(){localStorage.removeItem(K.logo);rLogo(null);toast('Logo eliminado');}
async function hSig(e){const f=e.target.files[0];if(!f)return;const b=await toB64(f);set(K.sig,b);rSig(b);toast('✅ Firma actualizada');}
function rSig(b){const img=$('cert-sig-img'),ph=$('cert-sig-ph'),p=$('cfg-sig-p'),t=$('cfg-sig-t');if(b){img.src=b;img.style.display='block';ph.style.display='none';p.src=b;p.style.display='block';t.style.display='none';}else{img.style.display='none';ph.style.display='flex';p.style.display='none';t.style.display='block';}}
function rmSig(){localStorage.removeItem(K.sig);rSig(null);toast('Firma eliminada');}

/* cats */
function getCats(){return get(K.cats)||DEF_CATS;}
function renderSvc(){const s=$('inp-service');s.innerHTML=getCats().map(c=>`<option value="${c}">${c}</option>`).join('');}
function renderCatsEd(){$('cats-ed').innerHTML=getCats().map((c,i)=>`<div class="cat-item" id="cr-${i}"><input type="text" value="${c}" id="ci-${i}"><button class="cat-del" onclick="document.getElementById('cr-${i}').remove()">✕</button></div>`).join('');}
function addCat(){const ed=$('cats-ed'),i=ed.children.length;const div=document.createElement('div');div.className='cat-item fi';div.id='cr-'+i;div.innerHTML=`<input type="text" id="ci-${i}" placeholder="Nuevo..."><button class="cat-del" onclick="this.parentElement.remove()">✕</button>`;ed.appendChild(div);div.querySelector('input').focus();}
function saveCats(){const c=[...document.querySelectorAll('#cats-ed input')].map(i=>i.value.trim()).filter(Boolean);set(K.cats,c);renderSvc();closeMo('mo-cats');toast('✅ Guardado');}

/* invoice */
function getInv(){return get(K.inv)||1;}
function updInv(n){$('inp-num').value=n.toString().padStart(4,'0');$('out-num').textContent=n.toString().padStart(4,'0');}
function incrInv(){const n=getInv()+1;set(K.inv,n);return n;}
function setInv(){const v=parseInt($('cfg-inv').value);if(v>0){set(K.inv,v);updInv(v);toast('Número actualizado');}}

/* clients */
function getDB(){return get(K.cl)||{};}
function saveDB(db){set(K.cl,db);}
function saveCl(name,data){const db=getDB(),key=name.toLowerCase().trim();db[key]={name:name.trim(),cid:data.cid||'',phone:data.phone||'',email:data.email||'',address:data.address||'',service:data.service||'',currency:data.currency||'COP',method:data.method||'Efectivo',lastUpdated:new Date().toISOString()};saveDB(db);}
function srchCl(q){const db=getDB(),n=q.toLowerCase().trim();return Object.values(db).filter(c=>c.name.toLowerCase().includes(n)||(c.cid&&c.cid.includes(n))||(c.phone&&c.phone.includes(n))).sort((a,b)=>a.name.localeCompare(b.name));}

/* autocomplete */
let acI=-1,acR=[];
$('inp-client').addEventListener('input',e=>{const v=e.target.value;if(v.length<2){clAC();chkTag(v);return;}acR=srchCl(v);rnAC(acR,v);chkTag(v);});
$('inp-client').addEventListener('keydown',e=>{const l=$('ac-list');if(!l.style.display||l.style.display==='none')return;if(e.key==='ArrowDown'){e.preventDefault();acI=Math.min(acI+1,acR.length-1);updACsel();}else if(e.key==='ArrowUp'){e.preventDefault();acI=Math.max(acI-1,-1);updACsel();}else if(e.key==='Enter'){e.preventDefault();if(acI>=0&&acR[acI])pickCl(acR[acI]);}else if(e.key==='Escape')clAC();});
document.addEventListener('click',e=>{if(!e.target.closest('.ac-wrap'))clAC();});
function rnAC(res,q){const l=$('ac-list');if(!res.length){clAC();return;}l.innerHTML=res.map((c,i)=>`<div class="ac-item" onclick="pickCl(acR[${i}])"><strong>${hl(c.name,q)}</strong><small>Doc: ${c.cid||'—'} | Tel: ${c.phone||'—'}</small></div>`).join('');l.style.display='block';acI=-1;}
function hl(t,q){return t.replace(new RegExp(`(${q})`,'gi'),'<mark style="background:#fef3c7;padding:0 2px;">$1</mark>');}
function updACsel(){document.querySelectorAll('.ac-item').forEach((el,i)=>el.classList.toggle('active',i===acI));}
function pickCl(c){$('inp-client').value=c.name;$('inp-cid').value=c.cid||'';$('inp-phone').value=c.phone||'';$('inp-email').value=c.email||'';$('inp-address').value=c.address||'';if(c.service)$('inp-service').value=c.service;$('inp-currency').value=c.currency||'COP';$('inp-method').value=c.method||'Efectivo';clAC();chkTag(c.name);$('inp-client').style.background='#d1fae5';setTimeout(()=>$('inp-client').style.background='',600);updC();}
function clAC(){$('ac-list').style.display='none';acI=-1;acR=[];}
function chkTag(n){const q=n.trim().toLowerCase();const db=getDB();const f=db[q]||Object.values(db).find(c=>c.cid&&c.cid===q);$('tag-new').style.display=q&&!f?'inline-block':'none';$('tag-saved').style.display=q&&f?'inline-block':'none';}

/* update cert */
function updC(){
  const c=get(K.cfg)||{};
  $('out-co').textContent=c.name||'MI NEGOCIO';
  $('out-rep').textContent=c.rep||'';
  $('out-nit').textContent=c.nit?'NIT: '+c.nit:'';
  $('out-city').textContent=c.city||'';
  $('out-tel').textContent=c.tel?'Tel: '+c.tel:'';
  $('out-rep-name').textContent=c.rep||'Firma Autorizada';
  $('out-rep-cc').textContent=c.repCc?'C.C. '+c.repCc:'';
  $('out-rep-cargo').textContent=c.cargo||'';
  $('out-c-email').textContent=c.email||'';
  $('out-c-web').textContent=c.web||'';
  $('out-slogan').textContent=c.slogan||'';
  $('out-c-city').textContent=c.city||'';
  $('out-intro').textContent=c.intro||((c.name||'La empresa')+' certifica que ha recibido el pago correspondiente por la prestación de servicios, bajo los términos que se detallan a continuación:');
  $('out-client').textContent=($('inp-client').value||'').toUpperCase()||'—';
  $('out-cid').textContent=$('inp-cid').value||'—';
  $('out-phone').textContent=$('inp-phone').value||'—';
  $('out-email').textContent=$('inp-email').value||'—';
  $('out-service').textContent=$('inp-service').value||'—';
  $('out-desc').textContent=$('inp-desc').value||'—';
  $('out-amount').textContent=parseFloat($('inp-amount').value)?fmtC(parseFloat($('inp-amount').value),$('inp-currency').value):'$ 0';
  $('out-method').textContent=$('inp-method').value||'—';
  $('out-date').textContent=$('inp-date').value?fmtD($('inp-date').value):'—';
  applyCol();
}

/* form */
$('pay-form').addEventListener('submit',e=>{e.preventDefault();doSC();updC();toast('✅ Cliente guardado y vista actualizada');});
function doSC(){const n=$('inp-client').value.trim();if(!n)return;saveCl(n,{cid:$('inp-cid').value,phone:$('inp-phone').value,email:$('inp-email').value,address:$('inp-address').value,service:$('inp-service').value,currency:$('inp-currency').value,method:$('inp-method').value});chkTag(n);}
function saveAndNew(){const f=$('pay-form');if(!f.checkValidity()){f.reportValidity();return;}doSC();updC();saveHS();const n=incrInv();updInv(n);const dv=$('inp-date').value;['inp-client','inp-cid','inp-phone','inp-email','inp-address','inp-desc','inp-amount'].forEach(id=>$(id).value='');$('inp-date').value=dv;$('tag-new').style.display='none';$('tag-saved').style.display='none';updC();toast('🎉 Guardado. Nuevo soporte listo.');}
function resetForm(){const dv=$('inp-date').value;$('pay-form').reset();$('inp-date').value=dv;$('tag-new').style.display='none';$('tag-saved').style.display='none';updC();}

/* history */
function getHS(){return get(K.hs)||[];}
function saveHS(){const h=getHS();h.unshift({id:Date.now(),num:$('inp-num').value,date:$('inp-date').value,client:$('inp-client').value,cid:$('inp-cid').value,phone:$('inp-phone').value,email:$('inp-email').value,service:$('inp-service').value,desc:$('inp-desc').value,amount:$('inp-amount').value,currency:$('inp-currency').value,method:$('inp-method').value,savedAt:new Date().toISOString()});set(K.hs,h);}
function renderHS(){const q=($('hs-search').value||'').toLowerCase();const list=getHS().filter(h=>!q||h.client.toLowerCase().includes(q)||h.num.includes(q)||(h.cid&&h.cid.includes(q)));const el=$('hs-list');if(!list.length){el.innerHTML='<div class="empty">No hay soportes guardados aún.</div>';return;}el.innerHTML=list.map(h=>`<div class="hi fi" onclick="loadHS(${h.id})"><div style="display:flex;justify-content:space-between;align-items:start;"><div><h4>N° ${h.num} — ${h.client}</h4><p>${fmtD(h.date)} | ${h.service}</p></div><span class="hi-a">${fmtC(parseFloat(h.amount)||0,h.currency)}</span></div></div>`).join('');}
function loadHS(id){const h=getHS().find(e=>e.id===id);if(!h)return;$('inp-client').value=h.client;$('inp-cid').value=h.cid||'';$('inp-phone').value=h.phone||'';$('inp-email').value=h.email||'';$('inp-service').value=h.service||'';$('inp-desc').value=h.desc||'';$('inp-amount').value=h.amount||'';$('inp-currency').value=h.currency||'COP';$('inp-method').value=h.method||'Efectivo';$('inp-date').value=h.date||'';$('inp-num').value=h.num||'';$('out-num').textContent=h.num||'0001';updC();swTab('soporte',document.querySelector('.tb'));toast('📋 Comprobante cargado');}

/* clients list */
let selK=null;
function renderCL(){const q=($('cl-search').value||'').toLowerCase();const db=getDB();const fl=Object.entries(db).filter(([k,c])=>!q||c.name.toLowerCase().includes(q)||(c.cid&&c.cid.includes(q)));const el=$('cl-list');if(!fl.length){el.innerHTML='<div class="empty">No hay clientes guardados aún.</div>';return;}el.innerHTML=fl.map(([k,c])=>`<div class="cc"><div onclick="showCl('${k}')" style="cursor:pointer;flex:1;"><h4>${c.name}</h4><p>Doc: ${c.cid||'—'} | Tel: ${c.phone||'—'}</p></div><div class="ca"><button class="bx" onclick="useCl('${k}')">Usar</button><button class="bx d" onclick="delCl('${k}')">✕</button></div></div>`).join('');}
function delCl(k){const db=getDB();delete db[k];saveDB(db);renderCL();toast('Cliente eliminado');}
function useCl(k){const c=getDB()[k];if(!c)return;pickCl(c);swTab('soporte',document.querySelector('.tb'));}
function showCl(k){const c=getDB()[k];if(!c)return;selK=k;$('cl-detail').innerHTML=`<div style="display:grid;gap:0.5rem;font-size:0.875rem;"><div><b>Nombre:</b> ${c.name}</div><div><b>Documento:</b> ${c.cid||'—'}</div><div><b>Teléfono:</b> ${c.phone||'—'}</div><div><b>Correo:</b> ${c.email||'—'}</div><div><b>Dirección:</b> ${c.address||'—'}</div><div><b>Servicio:</b> ${c.service||'—'}</div><div><b>Método:</b> ${c.method||'—'}</div></div>`;openMo('mo-cl');}
function useSelCl(){if(selK){useCl(selK);closeMo('mo-cl');}}

/* print & PDF */
function printDoc(){if(!$('pay-form').checkValidity()){$('pay-form').reportValidity();return;}updC();window.print();}
async function sharePDF(){
  if(!$('pay-form').checkValidity()){$('pay-form').reportValidity();return;}
  updC();
  const fab=$('fab-btn');fab.style.transform='scale(0.85)';
  fab.innerHTML='<div style="width:18px;height:18px;border:3px solid #fff;border-top-color:transparent;border-radius:50%;animation:spin 0.8s linear infinite;"></div>';
  const se=document.createElement('style');se.textContent='@keyframes spin{to{transform:rotate(360deg)}}';document.head.appendChild(se);
  const el=$('capture-area');const num=$('inp-num').value;
  const client=($('inp-client').value||'cliente').trim().replace(/\s+/g,'_');
  const cfg=get(K.cfg)||{};const biz=(cfg.name||'PagoDoc').replace(/\s+/g,'_');
  const fn=`${biz}_Soporte_${num}_${client}.pdf`;
  const opt={margin:[0,0,0,0],filename:fn,image:{type:'jpeg',quality:1.0},html2canvas:{scale:4,useCORS:true,letterRendering:true,scrollX:0,scrollY:0,windowWidth:el.scrollWidth,windowHeight:el.scrollHeight,backgroundColor:'#ffffff',logging:false},jsPDF:{unit:'mm',format:[215.9,279.4],orientation:'portrait',compress:false}};
  try{
    await document.fonts.ready;
    const blob=await html2pdf().set(opt).from(el).output('blob');
    const file=new File([blob],fn,{type:'application/pdf'});
    if(navigator.canShare&&navigator.canShare({files:[file]})){await navigator.share({files:[file],title:`Soporte N° ${num}`,text:`Soporte de pago N° ${num}`});}
    else{const url=URL.createObjectURL(blob);const a=document.createElement('a');a.href=url;a.download=fn;a.click();setTimeout(()=>URL.revokeObjectURL(url),100);toast('📥 PDF descargado');}
    setTimeout(()=>{if(confirm('¿Guardar en historial y generar el siguiente soporte?')){saveHS();const n=incrInv();updInv(n);const dv=$('inp-date').value;['inp-client','inp-cid','inp-phone','inp-email','inp-address','inp-desc','inp-amount'].forEach(id=>$(id).value='');$('inp-date').value=dv;updC();}},400);
  }catch(err){if(err.name!=='AbortError')toast('⚠️ Error al generar PDF. Usa Imprimir.');}
  finally{fab.style.transform='';fab.innerHTML=`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>`;}
}

/* export/import */
function expData(){const d={clients:getDB(),history:getHS(),config:get(K.cfg),cats:getCats(),invoiceNum:getInv(),exportedAt:new Date().toISOString()};const a=document.createElement('a');a.href=URL.createObjectURL(new Blob([JSON.stringify(d,null,2)],{type:'application/json'}));a.download='pagodoc-backup.json';a.click();toast('📤 Backup exportado');}
function doImp(e){const f=e.target.files[0];if(!f)return;const r=new FileReader();r.onload=ev=>{try{const d=JSON.parse(ev.target.result);if(d.clients)set(K.cl,d.clients);if(d.history)set(K.hs,d.history);if(d.config)set(K.cfg,d.config);if(d.cats)set(K.cats,d.cats);if(d.invoiceNum)set(K.inv,d.invoiceNum);loadCfgForm();renderSvc();updInv(getInv());toast('✅ Datos importados');}catch{toast('⚠️ Archivo inválido');}};r.readAsText(f);e.target.value='';}

/* init */
document.addEventListener('DOMContentLoaded',()=>{
  if(get(K.setup)){launchApp();}
  // si no hay setup: se queda en splash del onboarding
});

if('serviceWorker' in navigator){window.addEventListener('load',()=>{navigator.serviceWorker.register('./service-worker.js').then(r=>console.log('SW:',r.scope)).catch(e=>console.log('SW err:',e));});}
</script>
